#!/usr/bin/env bash
# Regenerate sanitized templates before every commit.
# Only runs if the gitignored source files exist on disk.
# make-template.sh is fast (sed only), so this adds negligible overhead.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if [ -f "$REPO_ROOT/lib/app-hotkeys.ahk" ] || [ -f "$REPO_ROOT/lib/config.ahk" ]; then
    echo "[pre-commit] Regenerating sanitized templates..."
    bash "$REPO_ROOT/dev-scripts/make-template.sh"
    git add "$REPO_ROOT/lib/app-hotkeys.template.ahk" "$REPO_ROOT/lib/config.template.ahk"
fi

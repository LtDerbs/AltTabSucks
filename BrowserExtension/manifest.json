{
  "manifest_version": 3,
  "name": "AltTabSucks",
  "version": "1.0.0",
  "description": "Hotkey based browser tab & window focus management & productivity utilities",
  "permissions": [
    "tabs",
    "windows",
    "storage"
  ],
  "options_page": "options.html",
  "host_permissions": [
    "http://localhost:9876/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AltTabSucks"
  },
  "background": {
    "service_worker": "background.js"
  }
}
